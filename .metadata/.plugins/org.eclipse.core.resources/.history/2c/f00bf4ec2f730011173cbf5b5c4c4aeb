<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">


<bean class="in.sp.beans.Address" id="address">
<property name="houseno" value="999"/>
<property name="city" value="Chandigarh"/>
<property name="pincode" value="326236"/>
</bean>

<bean class="in.sp.beans.Student" id="stdId" autowire="constructor">
<property name="rollno" value="525"/>
<property name="name" value="Prince"/>
</bean>

</beans>