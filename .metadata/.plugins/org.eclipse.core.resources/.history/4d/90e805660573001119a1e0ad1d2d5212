<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

  
  
  <bean class="in.sp.beans.Address" id="addrId"> 
  <property name="houseno" value="213"/>
  <property name="city" value="Gujrat"/>
  <property name="pincode" value="909090"/>
  </bean>
  
  <bean class="in.sp.beans.Student" id="stdId">
  <property name="rollno" value="523"/>
  <property name="name" value="Raj Malhotra"/>
  <property name="address" ref="addrId"/>
  </bean>
  
</beans>
